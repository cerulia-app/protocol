{
  "lexicon": 1,
  "id": "app.cerulia.rule.listSheetSchemas",
  "defs": {
    "main": {
      "type": "query",
      "description": "List character sheet schemas.",
      "parameters": {
        "type": "params",
        "properties": {
          "rulesetNsid": {
            "type": "string",
            "format": "nsid"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["items"],
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#sheetSchemaListItem"
              }
            },
            "cursor": {
              "type": "string"
            }
          }
        }
      }
    },
    "sheetSchemaListItem": {
      "type": "object",
      "required": ["schemaRef", "baseRulesetNsid", "schemaVersion", "title"],
      "properties": {
        "schemaRef": {
          "type": "string",
          "format": "at-uri"
        },
        "baseRulesetNsid": {
          "type": "string",
          "format": "nsid"
        },
        "schemaVersion": {
          "type": "string"
        },
        "title": {
          "type": "string",
          "maxLength": 640
        }
      }
    }
  }
}
