{
  "lexicon": 1,
  "id": "app.cerulia.rpc.createCharacterBranch",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Create character branch.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "baseSheetRef": {
              "type": "string",
              "format": "at-uri"
            },
            "branchKind": {
              "type": "string",
              "knownValues": [
                "campaign-fork",
                "local-override"
              ]
            },
            "branchLabel": {
              "type": "string",
              "maxLength": 640
            },
            "overridePayload": {
              "type": "unknown"
            },
            "visibility": {
              "type": "string",
              "knownValues": [
                "draft",
                "public"
              ]
            }
          },
          "required": [
            "baseSheetRef",
            "branchKind",
            "branchLabel"
          ]
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "app.cerulia.defs#mutationAck"
        }
      }
    }
  }
}
