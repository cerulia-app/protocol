        "properties": {
          "scenarioRef": {
            "type": "string",
            "format": "at-uri"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["scenario"],
          "properties": {
            "scenario": {
              "type": "ref",
              "ref": "app.cerulia.core.scenario"
            }
          }
        }
      }
    }
  }
}
