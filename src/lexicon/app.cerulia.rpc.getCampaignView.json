        "schema": {
          "type": "ref",
          "ref": "#output"
        }
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "campaign": {
          "type": "unknown"
        },
        "sessions": {
          "type": "unknown"
        },
        "ruleOverlay": {
          "type": "unknown"
        },
        "campaignSummary": {
          "type": "unknown"
        },
        "sessionSummaries": {
          "type": "unknown"
        },
        "ruleOverlaySummary": {
          "type": "unknown"
        }
      }
    }
  }
}
