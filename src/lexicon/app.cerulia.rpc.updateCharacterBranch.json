{
  "lexicon": 1,
  "id": "app.cerulia.rpc.updateCharacterBranch",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Update character branch.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "characterBranchRef": {
              "type": "string",
              "format": "at-uri"
            },
            "branchLabel": {
              "type": "string",
              "maxLength": 640
            },
            "overridePayload": {
              "type": "unknown"
            },
            "visibility": {
              "type": "string",
              "knownValues": [
                "draft",
                "public"
              ]
            }
          },
          "required": [
            "characterBranchRef"
          ]
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "app.cerulia.defs#mutationAck"
        }
      }
    }
  }
}
