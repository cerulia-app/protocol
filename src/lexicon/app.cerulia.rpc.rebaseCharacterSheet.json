{
  "lexicon": 1,
  "id": "app.cerulia.rpc.rebaseCharacterSheet",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Rebase character sheet to another schema.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "characterSheetRef": {
              "type": "string",
              "format": "at-uri"
            },
            "targetSheetSchemaRef": {
              "type": "string",
              "format": "at-uri"
            },
            "stats": {
              "type": "unknown"
            },
            "note": {
              "type": "string",
              "maxLength": 3000
            }
          },
          "required": [
            "characterSheetRef",
            "targetSheetSchemaRef"
          ]
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "app.cerulia.defs#mutationAck"
        }
      }
    }
  }
}
