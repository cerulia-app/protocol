{
  "lexicon": 1,
  "id": "app.cerulia.core.campaign",
  "defs": {
    "main": {
      "type": "record",
      "key": "any",
      "record": {
        "type": "object",
        "properties": {
          "campaignId": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "maxLength": 640
          },
          "houseRef": {
            "type": "string",
            "format": "at-uri"
          },
          "rulesetNsid": {
            "type": "string",
            "format": "nsid"
          },
          "sharedRuleProfileRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "at-uri"
            }
          },
          "visibility": {
            "type": "string",
            "knownValues": [
              "draft",
              "public"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          },
          "archivedAt": {
            "type": "string",
            "format": "datetime"
          },
          "updatedAt": {
            "type": "string",
            "format": "datetime"
          }
        },
        "required": [
          "campaignId",
          "title",
          "rulesetNsid",
          "visibility",
          "createdAt",
          "updatedAt"
        ]
      }
    }
  }
}
