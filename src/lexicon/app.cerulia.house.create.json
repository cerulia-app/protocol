{
  "lexicon": 1,
  "id": "app.cerulia.house.create",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Create house.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["title"],
          "properties": {
            "title": {
              "type": "string",
              "maxLength": 640
            },
            "canonSummary": {
              "type": "string",
              "maxLength": 3000
            },
            "defaultRuleProfileRefs": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "at-uri"
              }
            },
            "policySummary": {
              "type": "string",
              "maxLength": 3000
            },
            "externalCommunityUri": {
              "type": "string",
              "format": "uri"
            },
            "visibility": {
              "type": "string",
              "knownValues": ["draft", "public"]
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "app.cerulia.defs#mutationAck"
        }
      }
    }
  }
}
